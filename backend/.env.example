# Supabase (service role — never expose publicly)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Used by jose for JWT verification — find in Supabase dashboard > Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Admin user IDs (comma-separated) allowed to call sync/admin routes
ADMIN_USER_IDS=your_user_id_here

# Server
PORT=3000
